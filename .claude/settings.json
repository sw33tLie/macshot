{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-translations.sh",
            "description": "Keep en.lproj/Localizable.strings in sync with L(\"…\") calls after Swift edits."
          }
        ]
      }
    ]
  }
}
